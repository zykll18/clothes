# 数据库配置
DATABASE_URL="postgresql://username:password@localhost:5432/clothes_preview?schema=public"

# JWT密钥（生产环境请使用随机生成的密钥）
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Next.js配置
NEXTAUTH_URL="http://localhost:3000"

# 云存储配置（根据你的服务商填写）
# 阿里云OSS
# ALIYUN_OSS_REGION="oss-cn-hangzhou"
# ALIYUN_OSS_BUCKET="your-bucket-name"
# ALIYUN_OSS_ACCESS_KEY="your-access-key"
# ALIYUN_OSS_SECRET_KEY="your-secret-key"

# 腾讯云COS
# TENCENT_COS_REGION="ap-guangzhou"
# TENCENT_COS_BUCKET="your-bucket-name"
# TENCENT_COS_SECRET_ID="your-secret-id"
# TENCENT_COS_SECRET_KEY="your-secret-key"

# 文件上传配置
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
