# The current Prisma schema still hardcodes the local SQLite path; keep this as the intended env config shape until that alignment lands.
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
DASHSCOPE_API_KEY="your-dashscope-api-key"
NEXTAUTH_URL="http://localhost:3000"
# These upload limits are reserved for planned runtime validation and are not yet centrally consumed.
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
